Package: SLSEdesign
Title: Optimal Regression Design under the Second-Order Least Squares
        Estimator
Version: 0.1.0
Authors@R: 
    c(person(given = "Chi-Kuang", family = "Yeh",
             role = c("aut", "cre"),
             email = "cyeh@gsu.edu",
             comment = c(ORCID = "0000-0001-7057-2096")),
      person(given = "Julie", family = "Zhou",
